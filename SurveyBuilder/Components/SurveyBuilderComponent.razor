
<div class="survey-builder">
    <div class="builder-header">
        <h2>🛠 Survey Builder</h2>
        <input class="survey-title-input"
               @bind="_surveyTitle"
               placeholder="Survey title..." />
    </div>

    <div class="questions-container">
        @if (!Questions.Any())
        {
            <div class="empty-state">
                <p>No questions yet. Click <strong>Add Question</strong> to get started.</p>
            </div>
        }

        <div class="questions-grid">
            @foreach (var q in Questions)
            {
                <div class="question-wrapper @CardClass(q)"
                     draggable="true"
                     @ondragstart="e => OnDragStart(e, q)"
                     @ondragover:preventDefault="true"
                     @ondragover="e => OnDragOver(e, q)"
                     @ondragleave="() => OnDragLeave(q)"
                     @ondrop="() => OnDrop(q)"
                     @ondragend="OnDragEnd">
                    <div class="drag-handle" title="Drag to reorder">⠿</div>
                    <QuestionEditor Question="q"
                                    OnRemove="() => RemoveQuestion(q)"
                                    OnChanged="StateHasChanged" />
                </div>
            }
        </div>
    </div>

    <div class="builder-actions">
        <button class="btn secondary" @onclick="AddQuestion">+ Add Question</button>
        <button class="btn primary"
                @onclick="Publish"
                disabled="@(!Questions.Any())">
            Publish Survey ▶
        </button>
    </div>
</div>