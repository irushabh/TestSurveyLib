@page "/"
@using SurveyBuilder.Components
@using SurveyBuilder.Models
@using System.Text.Json

<PageTitle>Index</PageTitle>

<SurveyBuilderComponent Title="Customer Feedback" Questions="_questions" OnSurveyReady="HandleSurveyReady" />

@if (_questions is null)
{
    
}
else if (!_showResults)
{
    <SurveyRunner SurveyTitle="@_surveyTitle"
                  Questions="_questions"
                  OnSubmit="HandleSubmit" />
}
else
{
    <div class="results-panel">
        <h2>📊 Submission Received</h2>
        @foreach (var r in _responses!)
        {
            var q = _questions.First(x => x.Id == r.QuestionId);
            <div class="result-item">
                <strong>@q.Text</strong>
                <p>@GetAnswerText(r)</p>
            </div>
        }
        <button class="btn secondary" @onclick="Reset">Start Over</button>
    </div>
}

<div>
    @{
        jsonString = JsonSerializer.Serialize(_questions);
        <span>@jsonString</span>
    }
    <input type="button" class="btn btn-primary" value="Generate Class" @onclick="@GenerateClassFromString" />
</div>

@code {
    private List<SurveyQuestion>? _questions;
    private List<SurveyResponse>? _responses;
    private string _surveyTitle = "";
    private bool _showResults;
    private string jsonString = "";

    override protected void OnInitialized()
    {
        _questions = new List<SurveyQuestion>
        {
            new SurveyQuestion
            {
                Id = Guid.NewGuid(),
                Text = "How satisfied are you with our product?",
                Type = QuestionType.Rating,
                IsRequired = true,
                MaxRating = 5
            },
            new SurveyQuestion
            {
                Id = Guid.NewGuid(),
                Text = "What features would you like to see in the future?",
                Type = QuestionType.Text,
                IsRequired = false,
                MaxLength = 200
            },
            new SurveyQuestion
            {
                Id = Guid.NewGuid(),
                Text = "Which of the following best describes you?",
                Type = QuestionType.MultipleChoice,
                IsRequired = true,
                Options = new List<string> { "New Customer", "Returning Customer", "Just Browsing" }
            }
        };
    }

    public void GenerateClassFromString()
    {
        List<SurveyQuestion> _ques = JsonSerializer.Deserialize<List<SurveyQuestion>>(jsonString);

    }

    private void HandleSurveyReady(List<SurveyQuestion> questions)
    {
        _questions = questions;
        _surveyTitle = "Customer Feedback";
    }

    private void HandleSubmit(List<SurveyResponse> responses)
    {
        _responses = responses;
        _showResults = true;
    }

    private void Reset()
    {
        _questions = null;
        _responses = null;
        _showResults = false;
    }

    private string GetAnswerText(SurveyResponse r) =>
        r.TextAnswer is not null ? r.TextAnswer :
        r.SelectedOptions.Any() ? string.Join(", ", r.SelectedOptions) :
        r.RatingAnswer.HasValue ? $"{r.RatingAnswer} ★" :
        r.YesNoAnswer.HasValue ? (r.YesNoAnswer.Value ? "Yes" : "No") : "—";
}